# Google OAuth2 - https://console.cloud.google.com/
# Local dev redirect URI:  http://localhost:8081/callback
# Docker/prod redirect URI: https://your-domain.com/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: override server port (Docker defaults to 8080)
# PORT=8080

# --- GCP CI/CD (GitHub Actions secrets, not in .env) ---
# GCP_PROJECT_ID   your-gcp-project-id
# GCP_REGION       asia-east1
# GCP_SA_KEY       service account JSON key
# GCE_HOST         VM external IP
# GCE_USER         SSH username
# GCE_SSH_KEY      SSH private key