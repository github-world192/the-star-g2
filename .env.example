# Google OAuth2 - https://console.cloud.google.com/
# Local dev redirect URI:  http://localhost:8081/callback
# GCP VM redirect URI:     http://YOUR_VM_IP/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: override server port (Docker defaults to 8080)
# PORT=8080

# --- GCP manual deploy (shell env vars, not in .env) ---
# GCP_PROJECT_ID   your-gcp-project-id
# GCP_REGION       asia-east1
# IMAGE_TAG        latest